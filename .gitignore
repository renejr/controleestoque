# ==========================================
# GESTÃO DE ESTOQUE SAAS - GITIGNORE
# ==========================================

# ------------------------------------------
# BLOQUEIO DE ARQUIVOS GRANDES (> 80MB)
# ------------------------------------------
# Bloqueia arquivos de banco de dados locais gigantes, 
# binários pesados e modelos de IA soltos no projeto.
*.sqlite
*.sqlite3
*.db
*.bak
*.iso
*.tar
*.zip
*.gz
*.rar
*.7z
*.mp4
*.mkv
*.bin
*.pt
*.safetensors
*.gguf

# ------------------------------------------
# PYTHON / BACKEND / FASTAPI
# ------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# FastAPI / Configs
.env.local
.env.development
.env.production
alembic.ini.bak

